# Copiar este archivo como .env y completar los valores locales.
# NUNCA commitear el .env real — solo este .env.example

# Base de datos PostgreSQL
DATABASE_URL=postgres://usuario:contraseña@localhost:5432/mesa_click

# Puerto donde corre el servidor
PORT=8080

# Clave secreta para firmar los JWT (cambiar por una cadena larga y aleatoria)
JWT_SECRET=cambiar_esto_por_algo_muy_secreto

# Entorno: development | production
APP_ENV=development
